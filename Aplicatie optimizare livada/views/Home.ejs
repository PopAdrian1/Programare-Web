<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>


    <div class="topbar">

        <div class="left-buttons">
            <button onclick="location.href='/auth/istoric'">Istoric</button>

            <% if (user.role === 'admin') { %>
                <button onclick="location.href='/auth/UserList'">Users</button>
            <% } %>
        </div>

        <div class="right-button">
            <button class="logout" onclick="location.href='/auth/logout'">Logout</button>
        </div>

    </div>

    <div class="container">

        <!-- STÂNGA: REZULTAT -->
        <div class="left">
            <div id="rezultat">Livada</div>
        </div>

        <!-- DREAPTA: FORMULAR -->
        <div class="right">

            <h2>Parametri</h2>

            <form id="formular">

                <label>Suprafata</label>
                <input type="text" id="suprafata" name="suprafata" required>

                <label>Lungime</label>
                <input type="text" id="lungime" name="lungime" required>

                <label>Latime</label>
                <input type="text" id="latime" name="latime" required>

                <label>Distanta randuri</label>
                <input type="text" id="distanta_randuri" name="distanta_randuri" required>

                <label>Distanta coloane</label>
                <input type="text" id="distanta_coloane" name="distanta_coloane" required>

                <button type="submit">Generate</button>
            </form>

        </div>

    </div>

    <script>
        document.getElementById('formular').addEventListener('submit', async (e) => {
            e.preventDefault();

            document.getElementById('rezultat').innerHTML = 'Se proceseaza...';

            const response = await fetch('/livada/proceseaza', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },

                body: JSON.stringify({
                    suprafata: document.getElementById('suprafata').value,
                    lungime: document.getElementById('lungime').value,
                    latime: document.getElementById('latime').value,
                    rowSpacing: document.getElementById('distanta_randuri').value,
                    colSpacing: document.getElementById('distanta_coloane').value
                })
            });

            const data = await response.json();
            
            let continut = `<p>Fitness: ${data.fitness}%</p><table border="1">`;

            data.grid.forEach(rand => {
                continut += '<tr>';

                rand.forEach(copac => {
                    continut += copac
                        ? `<td class="cell"
                                onmouseenter="showTip(event, '${copac.specie}', '${copac.rootstock}', ${copac.scor})"
                                onmouseleave="hideTip()">
                                ${getIcon(copac.specie)}
                        </td>`
                        : '<td class="cell empty">🟫</td>';
                });

                continut += '</tr>';
            });

            continut += '</table>';
            document.getElementById('rezultat').innerHTML = continut;
        });

        function getIcon(specie) {
            if (!specie) return '🟫';
            specie = specie
                .toString()
                .toLowerCase()
                .trim();

            // elimină diacritice (foarte important!)
            specie = specie.normalize("NFD").replace(/[\u0300-\u036f]/g, "");

            if (specie.includes('mar')) return '🍎';
            if (specie.includes('par')) return '🍐';
            if (specie.includes('cires')) return '🍒';
            if (specie.includes('nuc')) return '🌰';

            return '🌳';
        }


        function showTip(e, specie, rootstock, scor) {
            let tip = document.getElementById("tooltipBox");

            tip.innerHTML = `
                <b>${specie}</b><br>
                Rootstock: ${rootstock}<br>
                Scor: ${scor}
            `;

            tip.style.display = "block";
            tip.style.left = e.pageX + "px";
            tip.style.top = e.pageY + "px";
        }

        function hideTip() {
            document.getElementById("tooltipBox").style.display = "none";
        }
    </script>

    <div id="tooltipBox"></div>
</body>

</html>