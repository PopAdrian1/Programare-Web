<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Istoric Livadă</title>

    <link rel="stylesheet" href="/css/istoric.css">
</head>

<body>

<div class="topbar">
    <button onclick="location.href='/auth/home'">
        ← Înapoi
    </button>
</div>

<h1>Istoric Livadă</h1>

<%

function getIcon(specie) {
    if (!specie) return '🟫';

    specie = specie
        .toString()
        .toLowerCase()
        .trim()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    if (specie.includes('mar')) return '🍎';
    if (specie.includes('par')) return '🍐';
    if (specie.includes('cires')) return '🍒';
    if (specie.includes('nuc')) return '🌰';

    return '🌳';
}

%>

<% istoric.forEach(item => { %>

<div class="livada-card" id="livada-<%= item._id %>">

    <!-- HEADER -->
    <div class="card-header">
        <div>
            <b>Fitness:</b> <%= item.rezultat.fitness %>%
        </div>

        <div>
            <b>Data:</b>
            <%= new Date(item.createdAt).toLocaleString('ro-RO') %>
        </div>
    </div>

    <div class="card-content">

        <!-- GRID -->
        <div class="livada-grid">

            <table>

                <% item.rezultat.grid.forEach(rand => { %>
                    <tr>

                        <% rand.forEach(copac => { %>

                            <% if (copac) { %>

                                <td
                                    onmouseenter="showTip(event,
                                        '<%= copac.specie %>',
                                        '<%= copac.rootstock %>',
                                        '<%= copac.scor %>')"
                                    onmouseleave="hideTip()">

                                    <%= getIcon(copac.specie) %>

                                </td>

                            <% } else { %>

                                <td class="empty">🟫</td>

                            <% } %>

                        <% }) %>

                    </tr>
                <% }) %>

            </table>

        </div>

        <!-- PARAMETRI -->
        <div class="parametri">

            <h3>Parametri</h3>

            <p><b>Suprafață:</b> <%= item.parametri.suprafata %></p>
            <p><b>Lungime:</b> <%= item.parametri.lungime %></p>
            <p><b>Lățime:</b> <%= item.parametri.latime %></p>
            <p><b>Rânduri:</b> <%= item.parametri.rowSpacing %></p>
            <p><b>Coloane:</b> <%= item.parametri.colSpacing %></p>

            <button
                class="delete-btn"
                onclick="deleteLivada('<%= item._id %>')">
                Șterge
            </button>

        </div>

    </div>

</div>

<% }) %>

<div id="tooltipBox"></div>

<script>

function showTip(e, specie, rootstock, scor) {

    const tip = document.getElementById("tooltipBox");

    tip.innerHTML = `
        <b>${specie}</b><br>
        Rootstock: ${rootstock}<br>
        Scor: ${scor}
    `;

    tip.style.display = "block";
    tip.style.left = (e.pageX + 10) + "px";
    tip.style.top = (e.pageY + 10) + "px";
}

function hideTip() {
    document.getElementById("tooltipBox").style.display = "none";
}

async function deleteLivada(id) {

    const ok = confirm("Sigur vrei să ștergi această livadă?");
    if (!ok) return;

    try {

        const res = await fetch(`/auth/istoric/${id}`, {
            method: 'DELETE'
        });

        const data = await res.json();

        if (data.success) {

            const el = document.getElementById(`livada-${id}`);

            if (el) {
                el.style.transition = "0.2s";
                el.style.opacity = "0";

                setTimeout(() => el.remove(), 200);
            }

        } else {
            alert("Eroare la ștergere");
        }

    } catch (err) {
        console.error(err);
        alert("Eroare server");
    }
}

</script>

</body>
</html>